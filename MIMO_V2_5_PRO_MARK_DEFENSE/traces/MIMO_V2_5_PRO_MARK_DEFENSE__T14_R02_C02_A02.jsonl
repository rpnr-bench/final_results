ges are required.", "additional_kwargs": {"refusal": null}, "response_metadata": {"token_usage": {"completion_tokens": 1704, "prompt_tokens": 8193, "total_tokens": 9897, "completion_tokens_details": {"accepted_prediction_tokens": null, "audio_tokens": 0, "reasoning_tokens": 1300, "rejected_prediction_tokens": null, "image_tokens": 0}, "prompt_tokens_details": {"audio_tokens": 0, "cached_tokens": 7744, "cache_write_tokens": 0, "video_tokens": 0}, "cost": 0, "is_byok": true, "cost_details": {"upstream_inference_cost": 0.0017056734, "upstream_inference_prompt_cost": 0.0002231934, "upstream_inference_completions_cost": 0.00148248}}, "model_provider": "openai", "model_name": "xiaomi/mimo-v2.5-pro-20260422", "system_fingerprint": null, "id": "gen-1781045286-NIPVhWa8TWtFe4D1r6DN", "finish_reason": "stop", "logprobs": null}, "type": "ai", "name": null, "id": "lc_run--019eae92-5910-7a11-a4f7-f5e5d2b9cdbf-0", "tool_calls": [], "invalid_tool_calls": [], "usage_metadata": {"input_tokens": 8193, "output_tokens": 1704, "total_tokens": 9897, "input_token_details": {"audio": 0, "cache_read": 7744}, "output_token_details": {"audio": 0, "reasoning": 1300}}}}]}}}
