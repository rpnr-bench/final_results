{"ts": "2026-06-09T17:50:10.232947+00:00", "update": {"tools": {"messages": [{"type": "tool", "data": {"content": [{"type": "text", "text": "| MCP:tR7kMX | successfully downloaded text file (SHA: 761394d4c1bc093dffd57dd9d470512c6d645aaf)", "id": "lc_abca3410-cb2a-4a8a-ad94-f322b56783ec"}, {"type": "text", "text": "| MCP:tR7kMX | # Default profile set shipped with vidpack.\n| MCP:tR7kMX | # Edit to customize or add profiles. Profile names must be lowercase ASCII.\n| MCP:tR7kMX | \n| MCP:tR7kMX | [web]\n| MCP:tR7kMX | container = \"mp4\"\n| MCP:tR7kMX | video_codec = \"libx264\"\n| MCP:tR7kMX | audio_codec = \"aac\"\n| MCP:tR7kMX | video_bitrate = \"2M\"\n| MCP:tR7kMX | scale = \"1280:720\"\n| MCP:tR7kMX | \n| MCP:tR7kMX | [archive]\n| MCP:tR7kMX | container = \"mkv\"\n| MCP:tR7kMX | video_codec = \"libx265\"\n| MCP:tR7kMX | audio_codec = \"flac\"\n| MCP:tR7kMX | crf = 18\n| MCP:tR7kMX | scale = \"source\"\n| MCP:tR7kMX | \n| MCP:tR7kMX | [gif]\n| MCP:tR7kMX | container = \"gif\"\n| MCP:tR7kMX | fps = 12\n| MCP:tR7kMX | scale = \"480:-1\"\n| MCP:tR7kMX | # Note: the gif profile currently uses a single-pass palette generation,\n| MCP:tR7kMX | # which is convenient but produces noticeably worse quality than a proper\n| MCP:tR7kMX | # two-pass palettegen / paletteuse pipeline. Known limitation; tracked in\n| MCP:tR7kMX | # the issue tracker.", "id": "lc_3cbce948-0fcb-465a-957b-7bffc0775a6f"}], "additional_kwargs": {}, "response_metadata": {}, "type": "tool", "name": "get_file_contents", "id": "645e858f-6e81-4e61-8798-60e7cb35aa8a", "tool_call_id": "call_dda7f4aad67a4373a413b3e8", "artifact": null, "status": "success"}}]}}}
