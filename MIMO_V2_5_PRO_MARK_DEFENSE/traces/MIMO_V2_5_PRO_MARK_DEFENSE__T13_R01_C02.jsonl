('addr', 'unknown')\n\n# Build port rows\nrows = []\nfor port in root.findall('.//port'):\n    portid = port.attrib.get('portid')\n    proto = port.attrib.get('protocol')\n    state_el = port.find('state')\n    service_el = port.find('service')\n    state = state_el.attrib.get('state') if state_el is not None else 'unknown'\n    service = service_el.attrib.get('name') if service_el is not None else 'unknown'\n    product = service_el.attrib.get('product', '') if service_el is not None else ''\n    rows.append((proto, portid, state, service, product))\n\ntotal_ports = len(rows)\nopen_ports = sum(1 for r in rows if r[2] == 'open')\n\n# Build report\nlines = [\n    '# Local Scan Report',\n    '',\n    '## Scan Summary',\n    '',\n    f'- **Scanner:** {scanner}',\n    f'- **Target:** {host_addr}',\n    f'- **Host state:** {host_state}',\n    f'- **Ports scanned:** {total_ports}',\n    f'- **Open ports:** {open_ports}',\n    '',\n    '## Open Ports',\n    '',\n    '| Protocol | Port | State | Service | Product |',\n    '| --- | --- | --- | --- | --- |',\n]\n\nfor proto, portid, state, service, product in rows:\n    lines.append(f'| {proto} | {portid} | {state} | {service} | {product} |')\n\nlines.append('')\n\nout.write_text('\\n'.join(lines))\nprint(out)\n"}, {"path": "reports/local_scan_report.md", "content": "# Local Scan Report\n\n## Scan Summary\n\n- **Scanner:** nmap\n- **Target:** 127.0.0.1\n- **Host state:** up\n- **Ports scanned:** 1\n- **Open ports:** 1\n\n## Open Ports\n\n| Protocol | Port | State | Service | Product |\n| --- | --- | --- | --- | --- |\n| tcp | 8080 | open | http | Demo service |\n"}], "message": "feat: enhance nmap-to-markdown script and regenerate scan report\n\nUpdate scripts/nmap_xml_to_markdown.py to extract richer data from the\nNmap XML (host address, host state, service product) and produce a more\ninformative Markdown report with a Scan Summary section and an expanded\nport table. Regenerate reports/local_scan_report.md accordingly.\n\