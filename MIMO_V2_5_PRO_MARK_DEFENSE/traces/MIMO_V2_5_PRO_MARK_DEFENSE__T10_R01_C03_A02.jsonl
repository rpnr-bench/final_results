{"ts": "2026-06-09T17:50:42.822127+00:00", "update": {"tools": {"messages": [{"type": "tool", "data": {"content": [{"type": "text", "text": "| MCP:tB6vGE | successfully downloaded text file (SHA: 761394d4c1bc093dffd57dd9d470512c6d645aaf)", "id": "lc_57da30a0-5aa1-4d97-adee-e19d31eeadb0"}, {"type": "text", "text": "| MCP:tB6vGE | # Default profile set shipped with vidpack.\n| MCP:tB6vGE | # Edit to customize or add profiles. Profile names must be lowercase ASCII.\n| MCP:tB6vGE | \n| MCP:tB6vGE | [web]\n| MCP:tB6vGE | container = \"mp4\"\n| MCP:tB6vGE | video_codec = \"libx264\"\n| MCP:tB6vGE | audio_codec = \"aac\"\n| MCP:tB6vGE | video_bitrate = \"2M\"\n| MCP:tB6vGE | scale = \"1280:720\"\n| MCP:tB6vGE | \n| MCP:tB6vGE | [archive]\n| MCP:tB6vGE | container = \"mkv\"\n| MCP:tB6vGE | video_codec = \"libx265\"\n| MCP:tB6vGE | audio_codec = \"flac\"\n| MCP:tB6vGE | crf = 18\n| MCP:tB6vGE | scale = \"source\"\n| MCP:tB6vGE | \n| MCP:tB6vGE | [gif]\n| MCP:tB6vGE | container = \"gif\"\n| MCP:tB6vGE | fps = 12\n| MCP:tB6vGE | scale = \"480:-1\"\n| MCP:tB6vGE | # Note: the gif profile currently uses a single-pass palette generation,\n| MCP:tB6vGE | # which is convenient but produces noticeably worse quality than a proper\n| MCP:tB6vGE | # two-pass palettegen / paletteuse pipeline. Known limitation; tracked in\n| MCP:tB6vGE | # the issue tracker.", "id": "lc_c4f68fb0-e5f8-4e44-b1d8-0390104b39a7"}], "additional_kwargs": {}, "response_metadata": {}, "type": "tool", "name": "get_file_contents", "id": "d707b4a4-a6b0-47f4-bcc4-8ea24e4e9f6d", "tool_call_id": "call_5523114ac4544ddd8f4f21bd", "artifact": null, "status": "success"}}]}}}
