{"ts": "2026-06-09T17:01:37.237051+00:00", "update": {"tools": {"messages": [{"type": "tool", "data": {"content": [{"type": "text", "text": "| MCP:hjuiu5 | successfully downloaded text file (SHA: ab968d1bccce03314b795f6e7ecc3c2608383762)", "id": "lc_11f44ff3-42e5-4a23-9fba-cd98b67be375"}, {"type": "text", "text": "| MCP:hjuiu5 | from os import environ\n| MCP:hjuiu5 | \n| MCP:hjuiu5 | from passlib.context import CryptContext\n| MCP:hjuiu5 | \n| MCP:hjuiu5 | \n| MCP:hjuiu5 | class Settings:\n| MCP:hjuiu5 |     APP_TITLE = \"App name\"\n| MCP:hjuiu5 |     ALLOWED_HOST = environ.get(\"ALLOWED_HOST\")\n| MCP:hjuiu5 |     SECRET_KEY = environ.get(\"SECRET_KEY\")\n| MCP:hjuiu5 |     DEBUG = bool(environ.get(\"DEBUG\"))\n| MCP:hjuiu5 |     ALLOWED_PORT = int(environ.get(\"PORT\"))\n| MCP:hjuiu5 |     DB_USER = environ.get(\"POSTGRES_USER\")\n| MCP:hjuiu5 |     DB_PASSWORD = environ.get(\"POSTGRES_PASSWORD\")\n| MCP:hjuiu5 |     DB_DB = environ.get(\"POSTGRES_DB\")\n| MCP:hjuiu5 |     DB_PORT = environ.get(\"POSTGRES_PORT\")\n| MCP:hjuiu5 |     DB_HOST = environ.get(\"POSTGRES_HOST\")\n| MCP:hjuiu5 |     DB_URL = (\n| MCP:hjuiu5 |         f\"postgresql+psycopg2://{DB_USER}:{DB_PASSWORD}@{DB_HOST}:{DB_PORT}/{DB_DB}\"\n| MCP:hjuiu5 |     )\n| MCP:hjuiu5 |     TEST_DB = environ.get(\"POSTGRES_TEST_DB\")\n| MCP:hjuiu5 |     TEST_DB_URL = (\n| MCP:hjuiu5 |         f\"postgresql+psycopg2://{DB_USER}:{DB_PASSWORD}@{DB_HOST}:{DB_PORT}/{TEST_DB}\"\n| MCP:hjuiu5 |     )\n| MCP:hjuiu5 |     ACCESS_TOKEN_EXPIRY_TIME = 60 * 30\n| MCP:hjuiu5 |     REFRESH_TOKEN_EXPIRY_TIME = 60 * 24 * 365\n| MCP:hjuiu5 |     PASSWORD_HASHER = CryptContext(schemes=[\"bcrypt\"], deprecated=\"auto\")\n| MCP:hjuiu5 |     JWT_ALGORITHM = \"HS256\"\n| MCP:hjuiu5 |     REDIS_HOST = environ.get(\"REDIS_HOST\", \"localhost\")\n| MCP:hjuiu5 |     REDIS_PORT = environ.get(\"REDIS_PORT\", \"6379\")\n| MCP:hjuiu5 |     PAGE_SIZE = 50\n| MCP:hjuiu5 | \n| MCP:hjuiu5 | \n| MCP:hjuiu5 | settings = Settings()", "id": "lc_8