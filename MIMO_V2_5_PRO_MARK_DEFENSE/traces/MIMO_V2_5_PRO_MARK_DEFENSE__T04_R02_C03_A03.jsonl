{"ts": "2026-06-09T17:03:45.821604+00:00", "update": {"tools": {"messages": [{"type": "tool", "data": {"content": [{"type": "text", "text": "| MCP:BJGLg0 | successfully downloaded text file (SHA: e0f90ac88e1236616df18600c7f7a5f80ac113c6)", "id": "lc_2cb47085-6eef-4083-b272-4ee48c6596ed"}, {"type": "text", "text": "| MCP:BJGLg0 | from datetime import datetime, timedelta\n| MCP:BJGLg0 | from typing import Any, Dict\n| MCP:BJGLg0 | \n| MCP:BJGLg0 | from fastapi.security import OAuth2PasswordBearer\n| MCP:BJGLg0 | from jose import jwt\n| MCP:BJGLg0 | \n| MCP:BJGLg0 | from app.services import BaseService\n| MCP:BJGLg0 | from app.settings import settings\n| MCP:BJGLg0 | \n| MCP:BJGLg0 | # for authentication that works seamlessly with OpenAPI\n| MCP:BJGLg0 | reuseable_oauth = OAuth2PasswordBearer(\n| MCP:BJGLg0 |     tokenUrl=\"/api/v1/user/login\",\n| MCP:BJGLg0 |     scheme_name=\"JWT\"\n| MCP:BJGLg0 | )\n| MCP:BJGLg0 | \n| MCP:BJGLg0 | \n| MCP:BJGLg0 | def hash_password(password: str) -> str:\n| MCP:BJGLg0 |     \"\"\"Creates a hash of the password\"\"\"\n| MCP:BJGLg0 |     hashed_password = settings.PASSWORD_HASHER.hash(password)\n| MCP:BJGLg0 |     return hashed_password\n| MCP:BJGLg0 | \n| MCP:BJGLg0 | \n| MCP:BJGLg0 | def verify_password(plain_password: str, hashed_password: str) -> bool:\n| MCP:BJGLg0 |     \"\"\"Checks if a password corresponds to a hash\"\"\"\n| MCP:BJGLg0 |     password_is_verified = settings.PASSWORD_HASHER.verify(\n| MCP:BJGLg0 |         plain_password, hashed_password\n| MCP:BJGLg0 |     )\n| MCP:BJGLg0 | \n| MCP:BJGLg0 |     return bool(password_is_verified)\n| MCP:BJGLg0 | \n| MCP:BJGLg0 | \n| MCP:BJGLg0 | def create_auth_token(payload: Dict[str, Any], expiry: int) -> str:\n| MCP:BJGLg0 |     \"\"\"\n| MCP:BJGLg0 |     This handles the encoding of user information into a token\n| MCP:BJGLg0 |     that can be used. It is generic so as to accomodate access and\n| MCP:BJGLg0 |     refresh token.\n| MCP:BJGLg0 |     \"\"\"\n| MCP:BJGLg0 |     e