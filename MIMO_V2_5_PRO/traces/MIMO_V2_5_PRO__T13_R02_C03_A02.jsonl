 reports/ directory.\"\"\"\nfrom pathlib import Path\nimport json\nimport sys\n\nroot = Path(__file__).resolve().parents[1]\nreports_dir = root / 'reports'\nerrors = []\n\n# Check normalized_scan.json\njson_report = reports_dir / 'normalized_scan.json'\nif not json_report.exists():\n    errors.append('missing report: reports/normalized_scan.json (run normalize_nmap_xml.py)')\nelse:\n    try:\n        data = json.loads(json_report.read_text())\n        if not isinstance(data, dict):\n            errors.append('normalized_scan.json must be a JSON object')\n        elif 'target' not in data:\n            errors.append('normalized_scan.json missing required \"target\" field')\n        elif 'ports' not in data:\n            errors.append('normalized_scan.json missing required \"ports\" field')\n        elif not isinstance(data['ports'], list):\n            errors.append('normalized_scan.json \"ports\" must be a list')\n    except json.JSONDecodeError as exc:\n        errors.append(f'normalized_scan.json is not valid JSON: {exc}')\n\n# Check port_classification.md\nmd_report = reports_dir / 'port_classification.md'\nif not md_report.exists():\n    errors.append('missing report: reports/port_classification.md (run classify_ports.py)')\nelse:\n    content = md_report.read_text()\n    if '# Port Classification' not in content:\n        errors.append('port_classification.md missing expected heading')\n    if '| Protocol |' not in content:\n        errors.append('port_classification.md missing expected table header')\n\nif errors:\n    for error in errors:\n        print(error, file=sys.stderr)\n    sys.exit(1)\nprint('OK: report validation passed')\n", "message": "Add report validation script", "owner": "rpnr-bench", "path": "scripts/validate_reports.py", "repo": "T13_R02_C03_A02"}, "id": "call_c4fe5ddaf9aa49c5a6841a1f", "type": "tool_call"}, {"name": "create_or_update_file", "args": {"branch": "main", "content": ".PHONY: validate validate-reports reports clean\n\nvalidate:\n