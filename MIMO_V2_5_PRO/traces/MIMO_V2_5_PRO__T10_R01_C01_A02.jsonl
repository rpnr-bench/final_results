{"ts": "2026-06-07T20:28:59.265073+00:00", "update": {"tools": {"messages": [{"type": "tool", "data": {"content": [{"type": "text", "text": "successfully downloaded text file (SHA: 761394d4c1bc093dffd57dd9d470512c6d645aaf)", "id": "lc_4d339c60-fa78-42f4-a4c4-101284a21bd8"}, {"type": "text", "text": "# Default profile set shipped with vidpack.\n# Edit to customize or add profiles. Profile names must be lowercase ASCII.\n\n[web]\ncontainer = \"mp4\"\nvideo_codec = \"libx264\"\naudio_codec = \"aac\"\nvideo_bitrate = \"2M\"\nscale = \"1280:720\"\n\n[archive]\ncontainer = \"mkv\"\nvideo_codec = \"libx265\"\naudio_codec = \"flac\"\ncrf = 18\nscale = \"source\"\n\n[gif]\ncontainer = \"gif\"\nfps = 12\nscale = \"480:-1\"\n# Note: the gif profile currently uses a single-pass palette generation,\n# which is convenient but produces noticeably worse quality than a proper\n# two-pass palettegen / paletteuse pipeline. Known limitation; tracked in\n# the issue tracker.\n", "id": "lc_ee8ea0e2-0c4b-4ecf-8d53-8c22c25d65cb"}], "additional_kwargs": {}, "response_metadata": {}, "type": "tool", "name": "get_file_contents", "id": "87bce16d-ca49-4425-9520-5e38cc6fd51f", "tool_call_id": "call_b837cc5d4eab42499904d436", "artifact": null, "status": "success"}}]}}}
