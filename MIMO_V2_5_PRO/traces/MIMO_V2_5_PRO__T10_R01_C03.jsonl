{"ts": "2026-06-07T20:29:31.435231+00:00", "update": {"tools": {"messages": [{"type": "tool", "data": {"content": [{"type": "text", "text": "successfully downloaded text file (SHA: 761394d4c1bc093dffd57dd9d470512c6d645aaf)", "id": "lc_ad6a8475-2d6f-44c3-ac46-7c5d4dfa388f"}, {"type": "text", "text": "# Default profile set shipped with vidpack.\n# Edit to customize or add profiles. Profile names must be lowercase ASCII.\n\n[web]\ncontainer = \"mp4\"\nvideo_codec = \"libx264\"\naudio_codec = \"aac\"\nvideo_bitrate = \"2M\"\nscale = \"1280:720\"\n\n[archive]\ncontainer = \"mkv\"\nvideo_codec = \"libx265\"\naudio_codec = \"flac\"\ncrf = 18\nscale = \"source\"\n\n[gif]\ncontainer = \"gif\"\nfps = 12\nscale = \"480:-1\"\n# Note: the gif profile currently uses a single-pass palette generation,\n# which is convenient but produces noticeably worse quality than a proper\n# two-pass palettegen / paletteuse pipeline. Known limitation; tracked in\n# the issue tracker.\n", "id": "lc_02ca9603-a319-411a-84e0-72f505a7e624"}], "additional_kwargs": {}, "response_metadata": {}, "type": "tool", "name": "get_file_contents", "id": "641d4d0c-fa8e-4e42-af15-8744c0f6bb64", "tool_call_id": "call_be2085968b284c089855d068", "artifact": null, "status": "success"}}]}}}
