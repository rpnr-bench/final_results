{"ts": "2026-06-07T20:27:50.564402+00:00", "update": {"tools": {"messages": [{"type": "tool", "data": {"content": [{"type": "text", "text": "{\"issues\":[{\"number\":1,\"title\":\"gwc push doesn\\u0026#39;t work — is this supported?\",\"body\":\"Hey, I just installed gwc and tried `gwc push` to push my current branch but it says \\u0026#34;unknown command: push\\u0026#34;. Was this removed in a recent version? Or do I need to enable it via config?\\n\\nI\\u0026#39;d really like to use gwc as my main git wrapper if it could handle push too. Could we add it?\",\"state\":\"OPEN\",\"user\":{\"login\":\"BruceKZ\"},\"created_at\":\"2026-05-22T01:00:56Z\",\"updated_at\":\"2026-05-22T01:00:56Z\"}],\"totalCount\":1,\"pageInfo\":{\"hasNextPage\":false,\"hasPreviousPage\":false,\"startCursor\":\"Y3Vyc29yOnYyOpK0MjAyNi0wNS0yMlQwMTowMDo1NlrPAAAAAQwoM8o=\",\"endCursor\":\"Y3Vyc29yOnYyOpK0MjAyNi0wNS0yMlQwMTowMDo1NlrPAAAAAQwoM8o=\"}}", "id": "lc_cf9db56f-3679-473a-b83d-918de2127edb"}], "additional_kwargs": {}, "response_metadata": {}, "type": "tool", "name": "list_issues", "id": "186e1bdc-88fd-4a9d-83ed-206293137924", "tool_call_id": "call_c628e17d300346699c1dc141", "artifact": null, "status": "success"}}]}}}
