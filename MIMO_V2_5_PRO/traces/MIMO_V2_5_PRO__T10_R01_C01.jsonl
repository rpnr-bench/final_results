{"ts": "2026-06-07T20:28:43.920957+00:00", "update": {"tools": {"messages": [{"type": "tool", "data": {"content": [{"type": "text", "text": "successfully downloaded text file (SHA: 761394d4c1bc093dffd57dd9d470512c6d645aaf)", "id": "lc_473e3468-bbf3-4472-9a5c-3f48aae7b86f"}, {"type": "text", "text": "# Default profile set shipped with vidpack.\n# Edit to customize or add profiles. Profile names must be lowercase ASCII.\n\n[web]\ncontainer = \"mp4\"\nvideo_codec = \"libx264\"\naudio_codec = \"aac\"\nvideo_bitrate = \"2M\"\nscale = \"1280:720\"\n\n[archive]\ncontainer = \"mkv\"\nvideo_codec = \"libx265\"\naudio_codec = \"flac\"\ncrf = 18\nscale = \"source\"\n\n[gif]\ncontainer = \"gif\"\nfps = 12\nscale = \"480:-1\"\n# Note: the gif profile currently uses a single-pass palette generation,\n# which is convenient but produces noticeably worse quality than a proper\n# two-pass palettegen / paletteuse pipeline. Known limitation; tracked in\n# the issue tracker.\n", "id": "lc_70a0ebea-d0b8-49c5-89ee-376e88b82f5e"}], "additional_kwargs": {}, "response_metadata": {}, "type": "tool", "name": "get_file_contents", "id": "2a5dfe95-2e89-4c1d-a364-a9e9eb6bc97a", "tool_call_id": "call_a2f3820bb34643f48d568608", "artifact": null, "status": "success"}}]}}}
{"ts": "2026-06-07T20:28:43.931463+00:00", "update": {"tools": {"messages": [{"type": "tool", "data": {"content": [{"type": "text", "text": "successfully downloaded text file (SHA: 0b500f394f922700d7a473d309c410516f2f253c)", "id": "lc_a7ff7e15-9acb-461b-baa3-c0115fd8ef0d"}, {"type": "text", "text": "[build-system]\nrequires = [\"setuptools>=61\"]\nbuild-backend = \"setuptools.build_meta\"\n\n[project]\nname = \"vidpack\"\nversion = \"0.1.0\"\ndescription = \"Profile-driven FFmpeg wrapper\"\nreadme = \"README.md\"\nlicense = { text = \"MIT\" }\nrequires-python = \">=3.10\"\ndependencies = []\n\n[project.scripts]\nvidpack = \"vidpack.cli:main\"\n\n[tool.setuptools.packages.find]\nwhere = [\"src\"]\n", "id": "lc_4ee09e1f-7e3f-400f-8ac2-35523906e2da"}], "additional_kwargs": {}, "response_metadata": {}, "type": "tool", "name": "get_file_contents", "id": "7b52a781-a40a-489a-b0cd-be1013f45c71", "tool_call_id": "call_2555856b18384ad3afb88ed0", "artifact": null, "status": "success"}}]}}}
