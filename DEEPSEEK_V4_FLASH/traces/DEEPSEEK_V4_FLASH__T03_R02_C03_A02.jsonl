",\"size\":4284,\"mode\":\"100644\",\"sha\":\"e245acdc31ca80b180894ffd6dd742f361325346\",\"url\":\"https://api.github.com/repos/rpnr-bench/T03_R02_C03_A02/git/blobs/e245acdc31ca80b180894ffd6dd742f361325346\"},{\"path\":\"build.gradle\",\"type\":\"blob\",\"size\":2985,\"mode\":\"100644\",\"sha\":\"7cff587e1bf9cc72465208736929b788029d9e8a\",\"url\":\"https://api.github.com/repos/rpnr-bench/T03_R02_C03_A02/git/blobs/7cff587e1bf9cc72465208736929b788029d9e8a\"},{\"path\":\"clients\",\"type\":\"tree\",\"mode\":\"040000\",\"sha\":\"3006ce210a671a9b1c414cf22bbfa154b9e07af0\",\"url\":\"https://api.github.com/repos/rpnr-bench/T03_R02_C03_A02/git/trees/3006ce210a671a9b1c414cf22bbfa154b9e07af0\"},{\"path\":\"core\",\"type\":\"tree\",\"mode\":\"040000\",\"sha\":\"7f55219c8ec72a5ab2f17a4847ef78e1575e7fd4\",\"url\":\"https://api.github.com/repos/rpnr-bench/T03_R02_C03_A02/git/trees/7f55219c8ec72a5ab2f17a4847ef78e1575e7fd4\"},{\"path\":\"gradle.properties\",\"type\":\"blob\",\"size\":432,\"mode\":\"100644\",\"sha\":\"8ecff550cc3cd0089c6e5421dbe2b60aa7c12c92\",\"url\":\"https://api.github.com/repos/rpnr-bench/T03_R02_C03_A02/git/blobs/8ecff550cc3cd0089c6e5421dbe2b60aa7c12c92\"},{\"path\":\"gradle\",\"type\":\"tree\",\"mode\":\"040000\",\"sha\":\"5fca500bb0af23e95cc249cc719ece7e65187aa3\",\"url\":\"https://api.github.com/repos/rpnr-bench/T03_R02_C03_A02/git/trees/5fca500bb0af23e95cc249cc719ece7e65187aa3\"},{\"path\":\"gradlew\",\"type\":\"blob\",\"size\":8733,\"mode\":\"100755\",\"sha\":\"23d15a9367071145e9c79bb4ddf879d1fbe78b5d\",\"url\":\"https://api.github.com/repos/rpnr-bench/T03_R02_C03_A02/git/blobs/23d15a9367071145e9c79bb4ddf879d1fbe78b5d\"},{\"path\":\"gradlew.bat\",\"type\":\"blob\",\"size\":2937,\"mode\":\"100644\",\"sha\":\"5eed7ee8452842305a18a4eb967442683808226a\",\"url\":\"https://api.github.com/repos/rpnr-bench/T03_R02_C03_A02/git/blobs/5eed7ee8452842305a18a4eb967442683808226a\"},{\"path\":\"lint.gradle\",\"type\":\"blob\",\"size\":209,\"mode\":\"100644\",\"sha\":\"ae2