{"ts": "2026-06-07T21:21:08.365280+00:00", "update": {"tools": {"messages": [{"type": "tool", "data": {"content": [{"type": "text", "text": "{\"issues\":[{\"number\":1,\"title\":\"gwc push doesn\\u0026#39;t work — is this supported?\",\"body\":\"Hey, I just installed gwc and tried `gwc push` to push my current branch but it says \\u0026#34;unknown command: push\\u0026#34;. Was this removed in a recent version? Or do I need to enable it via config?\\n\\nI\\u0026#39;d really like to use gwc as my main git wrapper if it could handle push too. Could we add it?\",\"state\":\"OPEN\",\"user\":{\"login\":\"BruceKZ\"},\"created_at\":\"2026-05-22T00:49:18Z\",\"updated_at\":\"2026-05-22T00:49:18Z\"}],\"totalCount\":1,\"pageInfo\":{\"hasNextPage\":false,\"hasPreviousPage\":false,\"startCursor\":\"Y3Vyc29yOnYyOpK0MjAyNi0wNS0yMlQwMDo0OToxOFrPAAAAAQwngWo=\",\"endCursor\":\"Y3Vyc29yOnYyOpK0MjAyNi0wNS0yMlQwMDo0OToxOFrPAAAAAQwngWo=\"}}", "id": "lc_88aafd02-8623-4ae6-b063-f5016d7de36c"}], "additional_kwargs": {}, "response_metadata": {}, "type": "tool", "name": "list_issues", "id": "cfab4aa2-e044-4291-89f4-6e253548236d", "tool_call_id": "call_00_HhdT0e710fXGh8YtzE809284", "artifact": null, "status": "success"}}]}}}
