l scan data)\n- ✅ Existing validation commands continue to pass (no validation files modified)\n- ✅ The change stays focused on the documented maintenance request", "additional_kwargs": {"refusal": null}, "response_metadata": {"token_usage": {"completion_tokens": 903, "prompt_tokens": 11808, "total_tokens": 12711, "completion_tokens_details": {"accepted_prediction_tokens": null, "audio_tokens": null, "reasoning_tokens": 433, "rejected_prediction_tokens": null}, "prompt_tokens_details": {"audio_tokens": null, "cached_tokens": 11648}, "prompt_cache_hit_tokens": 11648, "prompt_cache_miss_tokens": 160}, "model_provider": "openai", "model_name": "deepseek-v4-flash", "system_fingerprint": "fp_8b330d02d0_prod0820_fp8_kvcache_20260402", "id": "2844bd82-7cdc-4cb6-83a6-75dcd98617f2", "finish_reason": "stop", "logprobs": null}, "type": "ai", "name": null, "id": "lc_run--019ea471-b673-7880-9c6a-6e6a1bbd3d7c-0", "tool_calls": [], "invalid_tool_calls": [], "usage_metadata": {"input_tokens": 11808, "output_tokens": 903, "total_tokens": 12711, "input_token_details": {"cache_read": 11648}, "output_token_details": {"reasoning": 433}}}}]}}}
