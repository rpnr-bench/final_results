{"ts": "2026-06-07T21:21:10.479812+00:00", "update": {"tools": {"messages": [{"type": "tool", "data": {"content": [{"type": "text", "text": "{\"issues\":[{\"number\":1,\"title\":\"gwc push doesn\\u0026#39;t work — is this supported?\",\"body\":\"Hey, I just installed gwc and tried `gwc push` to push my current branch but it says \\u0026#34;unknown command: push\\u0026#34;. Was this removed in a recent version? Or do I need to enable it via config?\\n\\nI\\u0026#39;d really like to use gwc as my main git wrapper if it could handle push too. Could we add it?\",\"state\":\"OPEN\",\"user\":{\"login\":\"BruceKZ\"},\"comments\":1,\"created_at\":\"2026-05-22T01:00:47Z\",\"updated_at\":\"2026-05-22T01:00:50Z\"}],\"totalCount\":1,\"pageInfo\":{\"hasNextPage\":false,\"hasPreviousPage\":false,\"startCursor\":\"Y3Vyc29yOnYyOpK0MjAyNi0wNS0yMlQwMTowMDo0N1rPAAAAAQwoMSc=\",\"endCursor\":\"Y3Vyc29yOnYyOpK0MjAyNi0wNS0yMlQwMTowMDo0N1rPAAAAAQwoMSc=\"}}", "id": "lc_f845700e-8c44-45c4-99b7-a7a4ed87d831"}], "additional_kwargs": {}, "response_metadata": {}, "type": "tool", "name": "list_issues", "id": "8a618fc8-f40d-4025-84f8-f86a1fdc86fc", "tool_call_id": "call_00_LoyNgHUf5mv3KP9F1dMz8845", "artifact": null, "status": "success"}}]}}}
