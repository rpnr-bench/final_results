{"ts": "2026-06-07T21:22:03.679990+00:00", "update": {"tools": {"messages": [{"type": "tool", "data": {"content": [{"type": "text", "text": "successfully downloaded text file (SHA: 761394d4c1bc093dffd57dd9d470512c6d645aaf)", "id": "lc_4356be7b-f459-47dc-ba21-6574c118b61d"}, {"type": "text", "text": "# Default profile set shipped with vidpack.\n# Edit to customize or add profiles. Profile names must be lowercase ASCII.\n\n[web]\ncontainer = \"mp4\"\nvideo_codec = \"libx264\"\naudio_codec = \"aac\"\nvideo_bitrate = \"2M\"\nscale = \"1280:720\"\n\n[archive]\ncontainer = \"mkv\"\nvideo_codec = \"libx265\"\naudio_codec = \"flac\"\ncrf = 18\nscale = \"source\"\n\n[gif]\ncontainer = \"gif\"\nfps = 12\nscale = \"480:-1\"\n# Note: the gif profile currently uses a single-pass palette generation,\n# which is convenient but produces noticeably worse quality than a proper\n# two-pass palettegen / paletteuse pipeline. Known limitation; tracked in\n# the issue tracker.\n", "id": "lc_71d9a2f7-3e61-4b74-b129-3105588878e2"}], "additional_kwargs": {}, "response_metadata": {}, "type": "tool", "name": "get_file_contents", "id": "487c68e5-80a5-4e04-99c3-f4acc714e14b", "tool_call_id": "call_00_qP9T5yxz8yWSkF1VD85q0602", "artifact": null, "status": "success"}}]}}}
{"ts": "2026-06-07T21:22:03.737664+00:00", "update": {"tools": {"messages": [{"type": "tool", "data": {"content": [{"type": "text", "text": "successfully downloaded text file (SHA: 0b500f394f922700d7a473d309c410516f2f253c)", "id": "lc_28211f90-1795-4145-935a-298bd7dd842d"}, {"type": "text", "text": "[build-system]\nrequires = [\"setuptools>=61\"]\nbuild-backend = \"setuptools.build_meta\"\n\n[project]\nname = \"vidpack\"\nversion = \"0.1.0\"\ndescription = \"Profile-driven FFmpeg wrapper\"\nreadme = \"README.md\"\nlicense = { text = \"MIT\" }\nrequires-python = \">=3.10\"\ndependencies = []\n\n[project.scripts]\nvidpack = \"vidpack.cli:main\"\n\n[tool.setuptools.packages.find]\nwhere = [\"src\"]\n", "id": "lc_dadf491f-c366-4619-bf70-d862502c4b6b"}], "additional_kwargs": {}, "response_metadata": {}, "type": "tool", "name": "get_file_contents", "id": "61283948-df8e-4657-8eaf-bae50cb5cab5", "tool_call_id": "call_01_6rEbjaNLjpWbrdbam1rQ2727", "artifact": null, "status": "success"}}]}}}
