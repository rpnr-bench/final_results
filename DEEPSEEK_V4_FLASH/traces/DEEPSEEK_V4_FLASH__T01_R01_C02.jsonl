{"ts": "2026-06-08T13:38:40.608118+00:00", "update": {"tools": {"messages": [{"type": "tool", "data": {"content": [{"type": "text", "text": "successfully downloaded text file (SHA: 14e35346190d0ff04ea56d634a34dbac593ed1c9)", "id": "lc_de2ddb61-086e-4218-8010-2dfde25594df"}, {"type": "text", "text": "{\n  \"name\": \"vue3-vite-starter-template\",\n  \"description\": \"Vue.js 3 Vite starter template with Pinia, Vue Router, Bootstrap and more.\",\n  \"version\": \"0.0.0-semantic-release\",\n  \"license\": \"MIT\",\n  \"repository\": \"https://github.com/kouts/vue3-vite-starter-template\",\n  \"packageManager\": \"pnpm@10.20.0\",\n  \"type\": \"module\",\n  \"scripts\": {\n    \"preinstall\": \"npx only-allow pnpm\",\n    \"dev\": \"vite\",\n    \"build\": \"vite build\",\n    \"preview\": \"vite preview\",\n    \"build-preview\": \"vite build && vite preview\",\n    \"lint\": \"eslint \\\"**/*.{vue,ts,js}\\\"\",\n    \"lint-fix\": \"eslint --fix \\\"**/*.{vue,ts,js}\\\"\",\n    \"test:unit\": \"vitest\",\n    \"test:unit-coverage\": \"vitest run --coverage\",\n    \"prepare\": \"husky\"\n  },\n  \"dependencies\": {\n    \"bootstrap\": \"^5.3.8\",\n    \"jsdom\": \"^27.1.0\",\n    \"pinia\": \"^3.0.3\",\n    \"vitest\": \"^4.0.6\",\n    \"vue\": \"^3.5.22\",\n    \"vue-router\": \"^4.6.3\"\n  },\n  \"devDependencies\": {\n    \"@commitlint/cli\": \"^20.1.0\",\n    \"@commitlint/config-conventional\": \"^20.0.0\",\n    \"@fullhuman/postcss-purgecss\": \"^7.0.2\",\n    \"@fullhuman/vue-cli-plugin-purgecss\": \"^7.0.2\",\n    \"@kouts/eslint-config\": \"^3.0.9\",\n    \"@vitejs/plugin-vue\": \"^6.0.1\",\n    \"@vue/compiler-sfc\": \"^3.5.22\",\n    \"@vue/test-utils\": \"^2.4.6\",\n    \"autoprefixer\": \"^10.4.21\",\n    \"eslint\": \"^9.39.0\",\n    \"husky\": \"^9.1.7\",\n    \"lint-staged\": \"^16.2.6\",\n    \"prettier\": \"^3.6.2\",\n    \"sass\": \"^1.93.3\",\n    \"vite\": \"^7.1.12\",\n    \"vite-plugin-html\": \"^3.2.2\"\n  }\n}", "id": "lc_74df559a-f01a-4d0f-991