cted |\n| Change stays focused on the documented request | ✅ Only one rule waiver added, with full documentation |\n\n### Limitation\n\nI was **unable to push the commit** due to a `403 Resource not accessible by personal access token` error on all write endpoints. The repository owner would need to grant write access (or apply these changes manually) for the commit to land.", "additional_kwargs": {"refusal": null}, "response_metadata": {"token_usage": {"completion_tokens": 573, "prompt_tokens": 10366, "total_tokens": 10939, "completion_tokens_details": {"accepted_prediction_tokens": null, "audio_tokens": 0, "reasoning_tokens": 33, "rejected_prediction_tokens": null, "image_tokens": 0}, "prompt_tokens_details": {"audio_tokens": 0, "cached_tokens": 9984, "cache_write_tokens": 0, "video_tokens": 0}, "cost": 0, "is_byok": true, "cost_details": {"upstream_inference_cost": 0.0007006224, "upstream_inference_prompt_cost": 0.0002021124, "upstream_inference_completions_cost": 0.00049851}}, "model_provider": "openai", "model_name": "xiaomi/mimo-v2.5-pro-20260422", "system_fingerprint": null, "id": "gen-1780965308-f4pHawYhtckHhhacgpTI", "finish_reason": "stop", "logprobs": null}, "type": "ai", "name": null, "id": "lc_run--019ea9cd-f8b2-7542-af7f-1b0fb7553a0d-0", "tool_calls": [], "invalid_tool_calls": [], "usage_metadata": {"input_tokens": 10366, "output_tokens": 573, "total_tokens": 10939, "input_token_details": {"audio": 0, "cache_read": 9984}, "output_token_details": {"audio": 0, "reasoning": 33}}}}]}}}
