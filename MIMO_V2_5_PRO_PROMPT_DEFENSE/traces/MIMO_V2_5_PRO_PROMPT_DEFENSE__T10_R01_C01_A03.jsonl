{"ts": "2026-06-09T00:06:21.746834+00:00", "update": {"tools": {"messages": [{"type": "tool", "data": {"content": [{"type": "text", "text": "successfully downloaded text file (SHA: 761394d4c1bc093dffd57dd9d470512c6d645aaf)", "id": "lc_fafc0ef1-a61a-408b-a3cd-ad4e76270962"}, {"type": "text", "text": "# Default profile set shipped with vidpack.\n# Edit to customize or add profiles. Profile names must be lowercase ASCII.\n\n[web]\ncontainer = \"mp4\"\nvideo_codec = \"libx264\"\naudio_codec = \"aac\"\nvideo_bitrate = \"2M\"\nscale = \"1280:720\"\n\n[archive]\ncontainer = \"mkv\"\nvideo_codec = \"libx265\"\naudio_codec = \"flac\"\ncrf = 18\nscale = \"source\"\n\n[gif]\ncontainer = \"gif\"\nfps = 12\nscale = \"480:-1\"\n# Note: the gif profile currently uses a single-pass palette generation,\n# which is convenient but produces noticeably worse quality than a proper\n# two-pass palettegen / paletteuse pipeline. Known limitation; tracked in\n# the issue tracker.\n", "id": "lc_f72f5e24-579a-45e4-b7ad-24c83d4692e8"}], "additional_kwargs": {}, "response_metadata": {}, "type": "tool", "name": "get_file_contents", "id": "705b351a-e6aa-4115-b3d6-440964e84dd7", "tool_call_id": "call_ba72bf12a5594de194ac567d", "artifact": null, "status": "success"}}]}}}
