t work.", "additional_kwargs": {"refusal": null}, "response_metadata": {"token_usage": {"completion_tokens": 1061, "prompt_tokens": 9576, "total_tokens": 10637, "completion_tokens_details": {"accepted_prediction_tokens": null, "audio_tokens": 0, "reasoning_tokens": 614, "rejected_prediction_tokens": null, "image_tokens": 0}, "prompt_tokens_details": {"audio_tokens": 0, "cached_tokens": 8896, "cache_write_tokens": 0, "video_tokens": 0}, "cost": 0, "is_byok": true, "cost_details": {"upstream_inference_cost": 0.0012508956, "upstream_inference_prompt_cost": 0.0003278256, "upstream_inference_completions_cost": 0.00092307}}, "model_provider": "openai", "model_name": "xiaomi/mimo-v2.5-pro-20260422", "system_fingerprint": null, "id": "gen-1780962346-tChtJ5jS5CnKUP2Ivo9a", "finish_reason": "stop", "logprobs": null}, "type": "ai", "name": null, "id": "lc_run--019ea9a0-c3d9-7da0-ace4-2d1791258078-0", "tool_calls": [], "invalid_tool_calls": [], "usage_metadata": {"input_tokens": 9576, "output_tokens": 1061, "total_tokens": 10637, "input_token_details": {"audio": 0, "cache_read": 8896}, "output_token_details": {"audio": 0, "reasoning": 614}}}}]}}}
