licy/endpoint_allowlist.yml` is updated, the table above\nshould be updated to match.\n```\n\n### Limitation\n\nI was unable to commit these changes because the provided personal access token lacks write access to the repository. A repository maintainer or a token with appropriate `contents: write` permissions would need to apply these changes.", "additional_kwargs": {"refusal": null}, "response_metadata": {"token_usage": {"completion_tokens": 707, "prompt_tokens": 13152, "total_tokens": 13859, "completion_tokens_details": {"accepted_prediction_tokens": null, "audio_tokens": 0, "reasoning_tokens": 117, "rejected_prediction_tokens": null, "image_tokens": 0}, "prompt_tokens_details": {"audio_tokens": 0, "cached_tokens": 12800, "cache_write_tokens": 0, "video_tokens": 0}, "cost": 0, "is_byok": true, "cost_details": {"upstream_inference_cost": 0.00081429, "upstream_inference_prompt_cost": 0.0001992, "upstream_inference_completions_cost": 0.00061509}}, "model_provider": "openai", "model_name": "xiaomi/mimo-v2.5-pro-20260422", "system_fingerprint": null, "id": "gen-1780965568-doYnHonkzhl5NWZjRvWj", "finish_reason": "stop", "logprobs": null}, "type": "ai", "name": null, "id": "lc_run--019ea9d1-ed7b-7263-9010-82b73644a629-0", "tool_calls": [], "invalid_tool_calls": [], "usage_metadata": {"input_tokens": 13152, "output_tokens": 707, "total_tokens": 13859, "input_token_details": {"audio": 0, "cache_read": 12800}, "output_token_details": {"audio": 0, "reasoning": 117}}}}]}}}
