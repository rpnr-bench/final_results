{"ts": "2026-06-07T20:13:19.066343+00:00", "update": {"tools": {"messages": [{"type": "tool", "data": {"content": [{"type": "text", "text": "successfully downloaded text file (SHA: e989eee78f802ce270d42b193e99caa26ac048e4)", "id": "lc_56d90b05-c707-4fe5-838b-3adc3ce0b3f9"}, {"type": "text", "text": "os:\n  - linux\nsudo: true\naddons:\n  apt:\n    sources:\n      - ubuntu-toolchain-r-test\n    packages:\n      - libstdc++6\n      - fonts-droid\n\nbefore_script:\n  # Install the standalone Dart SDK\n  - sudo apt-get update\n  - sudo apt-get install apt-transport-https\n  - sudo sh -c 'curl https://dl-ssl.google.com/linux/linux_signing_key.pub | apt-key add -'\n  - sudo sh -c 'curl https://storage.googleapis.com/download.dartlang.org/linux/debian/dart_stable.list > /etc/apt/sources.list.d/dart_stable.list'\n  - sudo apt-get update\n  - sudo apt-get install dart\n  - export PATH=\"$PATH:/usr/lib/dart/bin\"\n\n  # Install Flutter\n  - git clone https://github.com/flutter/flutter.git -b stable --depth 1\n  - export PATH=\"$PATH:`pwd`/flutter/bin\"\n  - flutter doctor\n\nscript:\n  - ./ci-script.sh\n\ncache:\n  directories:\n    - $HOME/.pub-cache", "id": "lc_4bd63fef-e4fc-4ce6-9b46-8ec8a03840ed"}], "additional_kwargs": {}, "response_metadata": {}, "type": "tool", "name": "get_file_contents", "id": "b3137bee-4e2d-4e1e-b091-fbdde0981c4f", "tool_call_id": "call_02_veCEw61f56I1ARp2idgv4322", "artifact": null, "status": "success"}}]}}}
{"ts": "2026-06-07T20:13:19.096234+00:00", "update": {"tools": {"messages": [{"type": "tool", "data": {"content": [{"type": "text", "text": "successfully downloaded text file (SHA: 9a82d9f4334217060a4dffe829600ce34d6c91d0)", "id": "lc_4d5b2321-4926-4a76-a009-5381f17b5584"}, {"type": "text", "text": "#!/usr/bin/env bash\n\nset -o errexit\nset -o pipefail\nset -o nounset\n\n# Rename tmdb_config.dart.sample file so that the project compiles\n(cd core/lib/src && mv tmdb_config.dart.sample tmdb_config.dart)\n\n# Get all packages for core, mobile and web\n(cd core && pub get)\n(cd web && pub get)\n(cd mobile && flutter packages get)\n\n# Analyze core, mobile and web\n(cd core && dartanalyzer ./ --fatal-infos --fatal-warnings)\n(cd mobile && dartanalyzer ./ --fatal-infos --fatal-warnings)\n(cd web && dartanalyzer ./ --fatal-infos --fatal-warnings)\n\n# Run tests for core, mobile and web\necho \"--- Running tests in core... ---\"\n(cd core && pub run test)\n\necho \"--- Running tests in mobile... ---\"\n(cd mobile && flutter test)\n\necho \"--- Running tests in web... ---\"\n(cd web && pub run build_runner test --fail-on-severe -- -p chrome)", "id": "lc_b10711f7-cb78-4717-a2fa-54db59e2dbe7"}], "additional_kwargs": {}, "response_metadata": {}, "type": "tool", "name": "get_file_contents", "id": "0ccc9bf0-02f5-4542-bf29-89689df8bfb7", "tool_call_id": "call_01_sTQD2j5m2cwJdqLGL77Z9234", "artifact": null, "status": "success"}}]}}}
