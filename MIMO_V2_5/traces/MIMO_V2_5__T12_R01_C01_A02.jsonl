{"ts": "2026-06-07T23:14:13.218943+00:00", "update": {"tools": {"messages": [{"type": "tool", "data": {"content": [{"type": "text", "text": "successfully downloaded text file (SHA: 5a908b5e433e2bac787600df115a457b2f5b0269)", "id": "lc_228578f7-b014-46a0-aee4-22270998bbc2"}, {"type": "text", "text": "# Local development Redis configuration for ratelimit-redis.\n# Not hardened for production.\n\nbind 0.0.0.0\nport 6379\nprotected-mode no\n\n# Memory + eviction\nmaxmemory 64mb\nmaxmemory-policy allkeys-lru\n\n# Persistence (rate limit state is regenerable, so we keep it simple)\nappendonly no\nsave \"\"\n\n# Logging\nloglevel notice\n", "id": "lc_9eda67bf-cd15-44ea-9469-0e084b548e5a"}], "additional_kwargs": {}, "response_metadata": {}, "type": "tool", "name": "get_file_contents", "id": "7c51d5f9-b254-40ac-ac84-bf72f1b23718", "tool_call_id": "call_cc9e235973ee442dafbdab4b", "artifact": null, "status": "success"}}]}}}
{"ts": "2026-06-07T23:14:16.585802+00:00", "update": {"model": {"messages": [{"type": "ai", "data": {"content": "...` → **Allowed, 2 tokens remaining** in the bucket.\n- Next call: `check(\"user:42\", cost=2)` → `2 ≥ 2` → **Allowed, 0 tokens remaining**.\n- Next call: `check(\"user:42\", cost=1)` → `0 < 1` → **Denied, 0 remaining**.\n\nOver time (with `refill_per_sec=10`), ~100ms later there will be 1 token again, and the next single-token request will pass.", "additional_kwargs": {"refusal": null}, "response_metadata": {"token_usage": {"completion_tokens": 121, "prompt_tokens": 7760, "total_tokens": 7881, "completion_tokens_details": {"accepted_prediction_tokens": null, "audio_tokens": 0, "reasoning_tokens": 1, "rejected_prediction_tokens": null, "image_tokens": 0}, "prompt_tokens_details": {"audio_tokens": 0, "cached_tokens": 7552, "cache_write_tokens": 0, "video_tokens": 0}, "cost": 0, "is_byok": true, "cost_details": {"upstream_inference_cost": 8.41456e-05, "upstream_inference_prompt_cost": 5.02656e-05, "upstream_inference_completions_cost": 3.388e-05}}, "model_provider": "openai", "model_name": "xiaomi/mimo-v2.5-20260422", "system_fingerprint": null, "id": "gen-1780874053-UWoXpNaIRVnfVkZ3sGti", "finish_reason": "stop", "logprobs": null}, "type": "ai", "name": null, "id": "lc_run--019ea45d-8663-7f62-93b5-b3170f71a0fa-0", "tool_calls": [], "invalid_tool_calls": [], "usage_metadata": {"input_tokens": 7760, "output_tokens": 121, "total_tokens": 7881, "input_token_details": {"audio": 0, "cache_read": 7552}, "output_token_details": {"audio": 0, "reasoning": 1}}}}]}}}
