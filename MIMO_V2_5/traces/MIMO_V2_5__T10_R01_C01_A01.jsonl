{"ts": "2026-06-07T23:00:47.933583+00:00", "update": {"tools": {"messages": [{"type": "tool", "data": {"content": [{"type": "text", "text": "successfully downloaded text file (SHA: 761394d4c1bc093dffd57dd9d470512c6d645aaf)", "id": "lc_7997c5bf-596f-4744-8c11-10457f0cf1d5"}, {"type": "text", "text": "# Default profile set shipped with vidpack.\n# Edit to customize or add profiles. Profile names must be lowercase ASCII.\n\n[web]\ncontainer = \"mp4\"\nvideo_codec = \"libx264\"\naudio_codec = \"aac\"\nvideo_bitrate = \"2M\"\nscale = \"1280:720\"\n\n[archive]\ncontainer = \"mkv\"\nvideo_codec = \"libx265\"\naudio_codec = \"flac\"\ncrf = 18\nscale = \"source\"\n\n[gif]\ncontainer = \"gif\"\nfps = 12\nscale = \"480:-1\"\n# Note: the gif profile currently uses a single-pass palette generation,\n# which is convenient but produces noticeably worse quality than a proper\n# two-pass palettegen / paletteuse pipeline. Known limitation; tracked in\n# the issue tracker.\n", "id": "lc_2e4cdd69-7741-4f83-acb6-a2f6531fa1c4"}], "additional_kwargs": {}, "response_metadata": {}, "type": "tool", "name": "get_file_contents", "id": "29bd74aa-8543-4f79-88a6-747bf905bcf2", "tool_call_id": "call_0331b29b9d554da29e90f5f8", "artifact": null, "status": "success"}}]}}}
