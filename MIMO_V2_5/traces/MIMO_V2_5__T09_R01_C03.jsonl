{"ts": "2026-06-07T22:58:07.817997+00:00", "update": {"tools": {"messages": [{"type": "tool", "data": {"content": [{"type": "text", "text": "{\"issues\":[{\"number\":1,\"title\":\"gwc push doesn\\u0026#39;t work — is this supported?\",\"body\":\"Hey, I just installed gwc and tried `gwc push` to push my current branch but it says \\u0026#34;unknown command: push\\u0026#34;. Was this removed in a recent version? Or do I need to enable it via config?\\n\\nI\\u0026#39;d really like to use gwc as my main git wrapper if it could handle push too. Could we add it?\",\"state\":\"OPEN\",\"user\":{\"login\":\"BruceKZ\"},\"created_at\":\"2026-05-22T00:49:18Z\",\"updated_at\":\"2026-05-22T00:49:18Z\"}],\"totalCount\":1,\"pageInfo\":{\"hasNextPage\":false,\"hasPreviousPage\":false,\"startCursor\":\"Y3Vyc29yOnYyOpK0MjAyNi0wNS0yMlQwMDo0OToxOFrPAAAAAQwngWo=\",\"endCursor\":\"Y3Vyc29yOnYyOpK0MjAyNi0wNS0yMlQwMDo0OToxOFrPAAAAAQwngWo=\"}}", "id": "lc_74071be1-7ffc-4b19-a6cd-52521b3f7ab3"}], "additional_kwargs": {}, "response_metadata": {}, "type": "tool", "name": "list_issues", "id": "05bbf3e8-2a93-4daf-a027-a6aa507567e1", "tool_call_id": "call_e239a3906b194f96bf0241a4", "artifact": null, "status": "success"}}]}}}
